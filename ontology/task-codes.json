{
  "description": "Deconstruction task codes — operational tasks for full-house residential deconstruction. Each task is an ordered sequence of primitives with equipment, crew, and safety metadata. Bridges humanoid-ontology DCN task codes where applicable.",
  "bridgeNote": "Tasks with dcnCode field map to humanoid-ontology/nets/physical/dcn-task-codes.json. New codes are decon-lab originals derived from field research protocols.",
  "futureMerge": {
    "shiftModel": "Shift model integrated in crew-model.json. 90 min labor + 45 min solve = 2.25 hrs. Each task code has estimatedMinutes — shiftFit (how many repetitions fit in one 90-min labor block) will be calculated from field data.",
    "videoVerification": "Each task code will receive video annotation fields (keyFrames, qualityMetrics) matching humanoid-ontology/ontology/video-annotation-schema.json format."
  },
  "tasks": [
    {
      "code": "site_assess",
      "name": "Site Assessment",
      "phase": "PRE",
      "dcnCode": null,
      "description": "Walk site, assess structural condition, identify hazards, confirm scope, document existing conditions (photo/video).",
      "primitives": ["bipedal_transit", "inspect_visual", "measure", "mark"],
      "tools": { "required": ["clipboard", "camera", "tape_measure"], "optional": ["laser_measure", "moisture_meter"] },
      "ppe": ["hard_hat", "safety_glasses", "steel_toe_boots"],
      "difficulty": { "human": 2, "robot": 4 },
      "estimatedMinutes": 60,
      "crewSize": 2,
      "frequency": "1x per project"
    },
    {
      "code": "util_isolate",
      "name": "Utility Isolation",
      "phase": "PRE",
      "dcnCode": "ui",
      "description": "Shut down and physically disconnect all utilities — electrical, gas, water, sewer. Verify dead with test equipment.",
      "primitives": ["disconnect_utility", "lock_out_tag_out", "inspect_visual"],
      "tools": { "required": ["voltage_tester", "pipe_wrench", "loto_kit"], "optional": ["gas_detector"] },
      "ppe": ["hard_hat", "safety_glasses", "insulated_gloves", "steel_toe_boots"],
      "difficulty": { "human": 3, "robot": 5 },
      "estimatedMinutes": 90,
      "crewSize": 2,
      "frequency": "1x per project",
      "safetyNotes": "Licensed electrician and plumber for disconnects. Gas company shuts off gas."
    },
    {
      "code": "haz_survey",
      "name": "Hazmat Survey",
      "phase": "PRE",
      "dcnCode": "hzs",
      "description": "Sample and test for asbestos, lead paint, mold, PCBs. Pre-1978 homes assumed positive until tested.",
      "primitives": ["bipedal_transit", "inspect_visual", "hazmat_sample"],
      "tools": { "required": ["sampling_kit", "sealed_containers", "labels"], "optional": ["xrf_analyzer"] },
      "ppe": ["hard_hat", "n95_respirator", "nitrile_gloves", "tyvek_suit", "safety_glasses"],
      "difficulty": { "human": 3, "robot": 4 },
      "estimatedMinutes": 120,
      "crewSize": 1,
      "frequency": "1x per project",
      "safetyNotes": "Chain of custody for samples. Lab turnaround 3–5 days."
    },
    {
      "code": "haz_contain",
      "name": "Hazmat Containment",
      "phase": "PRE",
      "dcnCode": "hzc",
      "description": "Seal off areas with confirmed hazmat. Poly sheeting, negative pressure, wet methods.",
      "primitives": ["contain_hazmat", "fasten_staple", "inspect_visual"],
      "tools": { "required": ["poly_sheeting", "tape", "staple_gun"], "optional": ["negative_pressure_unit", "hepa_vacuum"] },
      "ppe": ["half_face_respirator", "tyvek_suit", "nitrile_gloves", "safety_glasses"],
      "difficulty": { "human": 3, "robot": 3 },
      "estimatedMinutes": 60,
      "crewSize": 2,
      "frequency": "as needed"
    },
    {
