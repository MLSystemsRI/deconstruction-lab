# ── Analytics ─────────────────────────────────────────────────────────
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Mode ──────────────────────────────────────────────────────────────
# "demo" = no Clerk, no DB, infinite tokens (default)
# "production" = Clerk auth + Supabase DB + real token billing
AUTH_MODE=demo

# ── Required ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: DALL-E / Vision renders ────────────────────────────
# OPENAI_API_KEY=sk-...

# ── Production mode only ─────────────────────────────────────────
# DATABASE_URL_POOLED=postgresql://...@...pooler.supabase.com:6543/postgres
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
# CLERK_SECRET_KEY=sk_live_...

# ── Stripe (production mode only) ───────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_DL_PRICE_SESSION=price_...
# STRIPE_DL_PRICE_EXPLORER=price_...
# STRIPE_DL_PRICE_BUILDER=price_...
